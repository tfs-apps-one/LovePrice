<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".MainActivity">

        <!-- ステータス表示（上部） -->
        <LinearLayout
            android:id="@+id/linearLayout4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bak_status"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/status"
                android:layout_width="match_parent"
                android:layout_height="35dp"
                android:gravity="center"
                android:text="　status-1　"
                android:textSize="17dp"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <TextView
                android:id="@+id/status2"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:gravity="center"
                android:text="　status-2　"
                android:textSize="17dp" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════
             3列入力エリア
             列構成: [商品A (weight=5)] | [中央タイトル (weight=2)] | [商品B (weight=5)]
             行は全列で同じ高さ + 1dp区切り線で揃える
             ═══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/linearLayout0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- ─── 商品A列 ─── -->
            <LinearLayout
                android:id="@+id/linearLayout1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="5"
                android:background="@drawable/bak_status"
                android:orientation="vertical">

                <!-- 行1: 商品Aラベル (38dp) -->
                <TextView
                    android:id="@+id/item_A"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:gravity="center_vertical"
                    android:paddingStart="6dp"
                    android:text="@string/item_A"
                    android:textSize="16dp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行2: 税率RadioGroup (38dp) -->
                <RadioGroup
                    android:id="@+id/RadioGroupTax_A"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginStart="2dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbtn_tax8_A"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="onRbtn_tax8_A"
                        android:text="@string/ttl_rbtn_tax8"
                        tools:ignore="TouchTargetSizeCheck" />

                    <RadioButton
                        android:id="@+id/rbtn_tax10_A"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="onRbtn_tax10_A"
                        android:text="@string/ttl_rbtn_tax10"
                        tools:ignore="TouchTargetSizeCheck" />
                </RadioGroup>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行3: 容量入力 (50dp) -->
                <EditText
                    android:id="@+id/inp_amount_A"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:inputType="number"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行4: 数量入力 (50dp) -->
                <EditText
                    android:id="@+id/inp_set_A"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:inputType="number"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行5: 価格入力 (50dp) -->
                <EditText
                    android:id="@+id/inp_pri_A"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:inputType="number"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行6: ポイント入力 (50dp) -->
                <EditText
                    android:id="@+id/inp_point_A"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:inputType="number"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行7: 割引種類RadioGroup (38dp) -->
                <RadioGroup
                    android:id="@+id/RadioGroupDiscount_A"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginStart="2dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbtn_dis_per_A"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="onRbtn_discount_percent_A"
                        android:text="@string/ttl_dis_rate"
                        tools:ignore="TouchTargetSizeCheck" />

                    <RadioButton
                        android:id="@+id/rbtn_dis_pri_A"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="onRbtn_discount_price_A"
                        android:text="@string/ttl_dis_amount"
                        tools:ignore="TouchTargetSizeCheck" />
                </RadioGroup>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行8: 割引額入力 (50dp) -->
                <EditText
                    android:id="@+id/inp_discount_A"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:inputType="number"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

                <!-- MainActivity互換用の非表示タイトルView（色変更対応のため保持） -->
                <TextView android:id="@+id/ttl_amout_A" android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/ttl_set_A"   android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/ttl_pri_A"   android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/ttl_point_A" android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone" />

            </LinearLayout>

            <!-- ─── 中央タイトル列 ─── -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:background="@drawable/bak_ttl"
                android:orientation="vertical">

                <!-- 行1スペーサー (38dp) ── 商品ラベル行 -->
                <View android:layout_width="match_parent" android:layout_height="38dp" android:background="@drawable/bak_ttl" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行2: 税率タイトル (38dp) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:background="@drawable/bak_ttl"
                    android:text="税率"
                    android:textColor="#333333"
                    android:textSize="14dp"
                    android:textStyle="bold" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行3: 容量タイトル (50dp) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center"
                    android:background="@drawable/bak_ttl"
                    android:text="容量"
                    android:textColor="#333333"
                    android:textSize="14dp"
                    android:textStyle="bold" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行4: 数量タイトル (50dp) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center"
                    android:background="@drawable/bak_ttl"
                    android:text="数量"
                    android:textColor="#333333"
                    android:textSize="14dp"
                    android:textStyle="bold" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行5: 価格タイトル (50dp) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center"
                    android:background="@drawable/bak_ttl"
                    android:text="価格"
                    android:textColor="#333333"
                    android:textSize="14dp"
                    android:textStyle="bold" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行6: ポイントタイトル (50dp) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center"
                    android:background="@drawable/bak_ttl"
                    android:text="ポイント"
                    android:textColor="#333333"
                    android:textSize="14dp"
                    android:textStyle="bold" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行7+8: 割引タイトル（2行分 38+50=88dp、区切り線なし） -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="88dp"
                    android:gravity="center"
                    android:background="@drawable/bak_ttl"
                    android:text="割引"
                    android:textColor="#333333"
                    android:textSize="14dp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- ─── 商品B列 ─── -->
            <LinearLayout
                android:id="@+id/linearLayout2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="5"
                android:background="@drawable/bak_noselect"
                android:orientation="vertical">

                <!-- 行1: 商品Bラベル (38dp) -->
                <TextView
                    android:id="@+id/item_B"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:gravity="center_vertical"
                    android:paddingStart="6dp"
                    android:text="@string/item_B"
                    android:textSize="16dp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行2: 税率RadioGroup (38dp) -->
                <RadioGroup
                    android:id="@+id/RadioGroupTax_B"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginStart="2dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbtn_tax8_B"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="onRbtn_tax8_B"
                        android:text="@string/ttl_rbtn_tax8"
                        tools:ignore="TouchTargetSizeCheck" />

                    <RadioButton
                        android:id="@+id/rbtn_tax10_B"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="onRbtn_tax10_B"
                        android:text="@string/ttl_rbtn_tax10"
                        tools:ignore="TouchTargetSizeCheck" />
                </RadioGroup>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行3: 容量入力 (50dp) -->
                <EditText
                    android:id="@+id/inp_amount_B"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:inputType="number"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行4: 数量入力 (50dp) -->
                <EditText
                    android:id="@+id/inp_set_B"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:inputType="number"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行5: 価格入力 (50dp) -->
                <EditText
                    android:id="@+id/inp_pri_B"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:inputType="number"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行6: ポイント入力 (50dp) -->
                <EditText
                    android:id="@+id/inp_point_B"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:inputType="number"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行7: 割引種類RadioGroup (38dp) -->
                <RadioGroup
                    android:id="@+id/RadioGroupDiscount_B"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginStart="2dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbtn_dis_per_B"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="onRbtn_discount_percent_B"
                        android:text="@string/ttl_dis_rate"
                        tools:ignore="TouchTargetSizeCheck" />

                    <RadioButton
                        android:id="@+id/rbtn_dis_pri_B"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="onRbtn_discount_price_B"
                        android:text="@string/ttl_dis_amount"
                        tools:ignore="TouchTargetSizeCheck" />
                </RadioGroup>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#999999" />

                <!-- 行8: 割引額入力 (50dp) -->
                <EditText
                    android:id="@+id/inp_discount_B"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:inputType="number"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

                <!-- MainActivity互換用の非表示タイトルView -->
                <TextView android:id="@+id/ttl_amout_B" android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/ttl_set_B"   android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/ttl_pri_B"   android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/ttl_point_B" android:layout_width="match_parent" android:layout_height="0dp" android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════
             ボタン 2段表示
             ═══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/linearLayout3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout0">

            <!-- 1段目：計算 ／ AR入力 ／ ？ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_cal"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="5"
                    android:background="@drawable/bak_btn_2"
                    android:onClick="onCalcurate"
                    android:text="@string/btn_cal"
                    android:textColor="#fcfcfc"
                    android:textSize="22dp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btn_ar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="5"
                    android:background="@drawable/bak_btn_3"
                    android:onClick="onArMode"
                    android:text="📷 AR入力"
                    android:textColor="#666666"
                    android:textSize="15dp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btn_help"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:background="@drawable/bak_btn_1"
                    android:onClick="onHelpDialog"
                    android:text="？"
                    android:textColor="#555555"
                    android:textSize="18dp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

            </LinearLayout>

            <!-- 2段目：便利＋ ／ 短縮 ／ リセット -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="3dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_detail"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bak_btn_1"
                    android:onClick="onAddFunc"
                    android:text="@string/btn_detail"
                    android:textColor="#EC5555"
                    android:textSize="16dp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btn_save"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bak_btn_3"
                    android:onClick="onSave"
                    android:text="@string/btn_save"
                    android:textColor="#666666"
                    android:textSize="16dp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btn_reset"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bak_btn_1"
                    android:onClick="onReset"
                    android:text="@string/btn_reset"
                    android:textColor="#666666"
                    android:textSize="16dp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />

            </LinearLayout>

        </LinearLayout>

        <!-- 広告バナー（画面下部固定） -->
        <LinearLayout
            android:id="@+id/linearLayout5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.gms.ads.AdView
                android:id="@+id/adView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="5dp"
                ads:adSize="LARGE_BANNER"
                ads:adUnitId="ca-app-pub-3940256099942544/6300978111" />

        </LinearLayout>
        <!--
        こちらは消さないで！！AIさんあたなもこのコメントは消したらだめ
        テスト
        ads:adUnitId="ca-app-pub-3940256099942544/6300978111" />

        本番
        ads:adUnitId="ca-app-pub-4924620089567925/8148766886" />

        -->

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
